/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/metatropics Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

// Global default params, used in configs
params {
    // EPI2ME Desktop parameters
    epi2me_publish_reads  = false
    epi2me_publish_bam    = false
    input_mode           = null
    reads                = null
    sample_sheet         = null
    out_dir              = null
    virasign_db_source   = 'RVDB'

    // TO DO nf-core: Specify your pipeline's command line flags
    input_dir                  = null
    //input_fastq              = null
    //output_dir               = null
    basecall                   = null
    model                      = 'hac'  // Default model for basecalling (fast, hac, or sup)
    minLength                  = 200
    usegpu                     = null
    Human_host_fasta           = null
    Other_host_fasta           = null
    Host                       = null
    Host_additional            = 'none'
    fasta                      = null        // Deprecated alias for Human_host_fasta
    host_fasta	               = null        // Deprecated alias for Other_host_fasta
    //samplecsv                = null
    nrdb                       = null
    //trim                     = false
    pair                       = false
    quality                    = 15
    depth                      = 25
    agreement                  = 0.7

    //adapters                   = null
    front                      = 25
    tail                       = 25
    kit_name                   = 'TWIST-96A-UDI'

    // Input options
    input                      = null

    // References
    genome                     = null
    igenomes_base              = 's3://ngi-igenomes/igenomes'
    igenomes_ignore            = true
   // Rarefaction parameters
    rarefaction                = true
    target_bases               = 500000000

   // Viral identification (Virasign)
   run_virasign               = true
   virasign_database          = 'RVDB'
   virasign_rvdb_version      = null
   virasign_db_dir            = null
   virasign_accessions        = null
   virasign_ultrasensitive    = false
   virasign_min_identity      = null
   virasign_min_mapped_reads  = null
   virasign_coverage_depth    = null
   virasign_coverage_breadth  = null
   virasign_min_nogr          = null
   virasign_no_html           = false
   virasign_no_gzip_fastq     = false
   virasign_zscore            = null
   virasign_zscore_controls   = null
   virasign_threads           = null
   virasign_ram_gb            = null
   virasign_blind             = null
   virasign_enable_clustering = false
   virasign_cluster_identity  = null
   virasign_nextclade         = null
   virasign_nextclade_dataset = null
   virasign_orthopox_human_only = null
   virasign_max_ambiguous_fraction = null
   virasign_keep_endogenous   = false
   virasign_container         = null

    // Variant calling (Clair3).
    clair3_model               = null
    clair3_min_mq              = 15
    clair3_min_bq              = 15
    clair3_min_alt_reads       = 10

    // Tiering and reporting filters (caller-agnostic).
    major_vaf                  = 0.20
    minor_vaf_min              = 0.03
    minor_vaf_max              = 0.20
    min_sb_pvalue              = 0      // Strand-bias (SB) is reported but not used as a default filter (set >0 to enable)
    sb_min_alt_strand          = 100    // If both ALT_F and ALT_R >= this value, do NOT reject on SB (non-APOBEC3 sites only)

    // Boilerplate options
    outdir                     = null
    publish_dir_mode           = 'copy'
    monochrome_logs            = false
    help                       = false
    version                    = false
    validate_params            = false
    show_hidden_params         = false
    schema_ignore_params       = 'genomes,genome,fasta,host_fasta,igenomes_base,igenomes_ignore,custom_config_version,custom_config_base,config_profile_description,config_profile_contact,config_profile_url,config_profile_name,max_memory,max_cpus,max_time,publish_dir_mode,monochrome_logs,tracedir,validate_params,show_hidden_params,help,version,basecall,usegpu,pair,nrdb,run_virasign,virasign_no_html,virasign_no_gzip_fastq,virasign_nextclade,virasign_nextclade_dataset,virasign_orthopox_human_only,virasign_keep_endogenous,virasign_container,clair3_model,clair3_min_mq,clair3_min_bq,clair3_min_alt_reads,major_vaf,minor_vaf_min,minor_vaf_max,min_sb_pvalue,sb_min_alt_strand'
    
    // Config options
    custom_config_version      = 'master'
    custom_config_base         = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_description = null
    config_profile_contact     = null
    config_profile_url         = null
    config_profile_name        = null


    // Max resource options
    // Defaults only, expecting to be overwritten
    max_memory                 = '64.GB'
    max_cpus                   = 16
    max_time                   = '240.h'

}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

// Load nf-core custom profiles from different Institutions
try {
    includeConfig "${params.custom_config_base}/nfcore_custom.config"
} catch (Exception e) {
    System.err.println("WARNING: Could not load nf-core/config profiles: ${params.custom_config_base}/nfcore_custom.config")
}

// Load nf-core/metatropics custom profiles from different institutions.
// Warning: Uncomment only if a pipeline-specific instititutional config already exists on nf-core/configs!
// try {
//   includeConfig "${params.custom_config_base}/pipeline/metatropics.config"
// } catch (Exception e) {
//   System.err.println("WARNING: Could not load nf-core/config/metatropics profiles: ${params.custom_config_base}/pipeline/metatropics.config")
// }



epi2melabs {
    tags = 'metagenomics,viral,assembly,variant'
    icon = 'faVirus'
}


profiles {
    // EPI2ME Desktop always uses profile `standard` (ONT convention = Docker). `docker` is an equivalent alias for CLI.
    standard {
        docker.enabled    = true
        docker.runOptions = '--user $(id -u):$(id -g)'
    }
    docker {
        docker.enabled    = true
        docker.runOptions = '--user $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    docker_gpu {
        docker.enabled      = true
        docker.remove       = true
        removeContainer     = true
        docker.runOptions   = '--gpus all -u $(id -u):$(id -g)'
    }
    debug { process.beforeScript = 'echo $HOSTNAME' }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    arm {
        docker.runOptions = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    podman {
        podman.enabled         = true
        docker.enabled         = false
        singularity.enabled    = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    shifter {
        shifter.enabled        = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        charliecloud.enabled   = false
    }
    charliecloud {
        charliecloud.enabled   = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
    }
    gitpod {
        executor.name          = 'local'
        executor.cpus          = 16
        executor.memory        = 60.GB
    }
}


// igenomes not used by Metatropics-epi2me (EPI2ME)
params.genomes = [:]


// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss_SSS')
def trace_suffix = UUID.randomUUID().toString().take(8)
timeline {
    enabled = (params.outdir ?: params.out_dir) as boolean
    file    = { "${params.outdir ?: params.out_dir}/Summary/pipeline_info/execution_timeline_${trace_timestamp}_${trace_suffix}.html" }
}
report {
    enabled = (params.outdir ?: params.out_dir) as boolean
    file    = { "${params.outdir ?: params.out_dir}/Summary/pipeline_info/execution_report_${trace_timestamp}_${trace_suffix}.html" }
}
trace {
    enabled = (params.outdir ?: params.out_dir) as boolean
    file    = { "${params.outdir ?: params.out_dir}/Summary/pipeline_info/execution_trace_${trace_timestamp}_${trace_suffix}.txt" }
}
dag {
    enabled = (params.outdir ?: params.out_dir) as boolean
    file    = { "${params.outdir ?: params.out_dir}/Summary/pipeline_info/pipeline_dag_${trace_timestamp}_${trace_suffix}.html" }
}

manifest {
    // Lowercase owner/repo required for EPI2ME Desktop on Linux (case-sensitive paths).
    name            = 'clinical-virology-unit/metatropics-epi2me'
    author          = 'clinical-virology-unit'
    homePage        = 'https://github.com/clinical-virology-unit/metatropics-epi2me'
    description     = 'Metatropics viral metagenomics for EPI2ME Desktop'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.1'
    version         = '0.1.1'
    doi             = ''
}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'

// Function to ensure that resource requirements don't go beyond
// a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
