/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Results are grouped under outdir:
      Basecalling/   — POD5 Dorado (optional)
      Reads/         — QC, trimming, host depletion
      Classification/ — Virasign per-sample viral classification
      Variant_calling/ — Clair3 VCFs and HTML report
      Consensus/     — bcftools consensus
      Summary/       — final Metatropics summary, plus readcounts and pipeline_info
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

def wfOutdir = { -> (params.outdir ?: params.out_dir)?.toString() }

// VirasignDb is not on the classpath inside modules.config publishDir closures.
def virasignDbLabel = { ->
    def source = params.virasign_db_source?.toString()?.trim()
    def raw = null
    if (source) {
        switch (source.toUpperCase()) {
            case 'RVDB':
                raw = 'RVDB'
                break
            case 'REFSEQ':
                raw = 'RefSeq'
                break
            case 'CUSTOM':
                def acc = params.virasign_accessions?.toString()?.trim()
                if (acc) {
                    raw = acc.split(',')[0].trim()
                }
                break
        }
    }
    if (!raw) {
        raw = params.virasign_database?.toString()?.trim() ?: 'RVDB'
    }
    raw.replaceAll(/[^A-Za-z0-9._-]+/, '_')
}

process {

    // Do not publish anything by default. Each process that should publish outputs
    // must define its own `publishDir` block below.
    publishDir = [ enabled: false ]

    withName: SOFTWARE_VERSIONS {
        publishDir = [
            path: { "${wfOutdir()}/Summary/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString().tokenize('/').last()
                // Keep only the primary software versions file; drop MultiQC helper + module-internal versions.yml.
                if (fn == 'software_versions.yml') {
                    return fn
                }
                return null
            }
        ]
    }

    // Internal barrier process; do not publish any outputs into outdir.
    withName: VIRASIGN_DB {
        publishDir = [ enabled: false ]
    }

    withName: SAMPLESHEET_CHECK_METATROPICS {
        // The validated samplesheet is useful for debugging, but is not part of the final report outputs.
        publishDir = [ enabled: false ]
    }

    withName: FIX_NAMES {
        // Always publish during the run (same pattern as VIRASIGN_CLASSIFICATION). onComplete
        // removes Reads/ when epi2me_publish_reads=false.
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/raw" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep fixed reads only; drop versions.yml.
                if (fn.endsWith('.fastq.gz')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: RAREFACTION {
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/rarefaction" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep rarefied reads only; drop versions.yml.
                if (fn.endsWith('_rarefied.fastq.gz')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: FASTPLONG {
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/fastplong" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep only the cleaned read set; drop QC side-products and versions.yml.
                if (fn.endsWith('.fastp.fastq.gz')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
        ext.args = "-f '${params.front}' -t '${params.tail}' -m '${params.quality}' -q '${params.quality}' -l '${params.minLength}' -y"
    }

    withName: NANOPLOT {
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/nanoplot/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep only the interactive HTML outputs; drop PNG/TXT/LOG/total_reads and versions.yml.
                if (fn.endsWith('.html')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: DORADO_ONT {
        publishDir = [
            enabled: { !params.reads?.toString()?.trim() },
            path: { "${wfOutdir()}/Basecalling/basecalling" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep basecalling BAM only; drop versions.yml.
                if (fn.endsWith('.bam')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: DORADO_DEMULTIPLEXING {
        publishDir = [
            enabled: { !params.reads?.toString()?.trim() },
            path: { "${wfOutdir()}/Basecalling/demultiplexing" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                // Keep demultiplexed FASTQs only; drop versions.yml.
                if (fn.endsWith('.fastq')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: MINIMAP2_ALIGN {
        publishDir = [ enabled: false ]
        ext.args = "-ax map-ont"
    }

    withName: SAMTOOLS_hFASTQ {
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/nohuman" },
            mode: params.publish_dir_mode,
            pattern: '*.fastq.gz',
            saveAs: { filename ->
                def fn = filename.toString().tokenize('/').last()
                // Rename / filter for human mapping:
                //   *_other.fastq.gz     -> *_human_depleted.fastq.gz (reads NOT mapped to human; downstream input)
                //   *_1.fastq.gz         -> *_human.fastq.gz          (reads mapped to human)
                //   *_singleton.fastq.gz -> dropped
                if (fn.endsWith('_other.fastq.gz')) {
                    return fn.replaceFirst(/_other\.fastq\.gz$/, '_human_depleted.fastq.gz')
                }
                if (fn.endsWith('_1.fastq.gz')) {
                    return fn.replaceFirst(/_1\.fastq\.gz$/, '_human.fastq.gz')
                }
                return null
            }
        ]
        // Flags (-f/-F) are handled inside the module so it can emit BOTH:
        //   mapped reads   -> *_1.fastq.gz
        //   unmapped reads -> *_other.fastq.gz
        ext.args = ""
    }

    withName: SAMTOOLS_hoFASTQ {
        publishDir = [
            enabled: true,
            path: { "${params.outdir ?: params.out_dir}/Reads/nohost" },
            mode: params.publish_dir_mode,
            pattern: '*.fastq.gz',
            saveAs: { filename ->
                def fn = filename.toString().tokenize('/').last()
                // Rename / filter for other-host mapping:
                //   *_other.fastq.gz     -> *_host_depleted.fastq.gz  (reads NOT mapped to host; downstream input)
                //   *_1.fastq.gz         -> *_host.fastq.gz           (reads mapped to host)
                //   *_singleton.fastq.gz -> dropped
                if (fn.endsWith('_other.fastq.gz')) {
                    return fn.replaceFirst(/_other\.fastq\.gz$/, '_host_depleted.fastq.gz')
                }
                if (fn.endsWith('_1.fastq.gz')) {
                    return fn.replaceFirst(/_1\.fastq\.gz$/, '_host.fastq.gz')
                }
                return null
            }
        ]
        // Flags (-f/-F) are handled inside the module so it can emit BOTH:
        //   mapped reads   -> *_1.fastq.gz
        //   unmapped reads -> *_other.fastq.gz
        ext.args = ""
    }

    withName: SAMTOOLS_SORT {
        publishDir = [ enabled: false ]
        ext.prefix = { "${meta.id}.sorted" }
    }

    withName: VIRASIGN_CLASSIFICATION {
        // Always publish to Classification/virasign so summary/readcount can read JSON during the run.
        // When EPI2ME BAM publishing is off, publish per-sample final_selected JSON (confident hits
        // or empty [] for negatives) plus per-hit accession JSON (coverage_profile for summary plots).
        // onComplete removes Classification/ after reports are built. Full BAM tree when publishEpi2meBam is true.
        publishDir = [
            enabled: true,
            path: {
                "${wfOutdir()}/Classification/virasign/${virasignDbLabel()}"
            },
            mode: 'copy',
            overwrite: true,
            saveAs: { filename ->
                def fn = filename.toString()
                if (!fn.startsWith('publish/')) {
                    return null
                }
                def rel = fn.substring('publish/'.length())
                // saveAs delegate shadows script closures; inline Epi2meParams.publishBam logic.
                def publishFullTree = !params.reads?.toString()?.trim() || params.epi2me_publish_bam
                if (publishFullTree) {
                    return rel
                }
                if (rel.contains('_final_selected_references.json')) {
                    return rel
                }
                // Per-hit artifact JSON: sample/accession/accession.json (interactive coverage plot data).
                def parts = rel.split('/')
                if (parts.length == 3 && parts[2].endsWith('.json')) {
                    def accDir = parts[1]
                    def jsonStem = parts[2].replaceAll(/\.json$/, '')
                    if (accDir == jsonStem) {
                        return rel
                    }
                }
                return null
            },
        ]
    }

    withName: METATROPICS_SUMMARY {
        // Summary HTML/CSV only (per-sample trees stay under Classification/virasign). Publishing into the
        // same dir virasign writes to caused publishDir symlink failures (path already occupied).
        publishDir = [
            path: { "${wfOutdir()}/Summary/metatropics" },
            mode: params.publish_dir_mode,
            pattern: 'Metatropics_Summary_*'
        ]
    }

    withName: CLAIR3_VARIANTS {
        // Clair3 intermediate outputs stay in work/; publish tiered VCF + HTML from CLAIR3_POSTPROCESSING.
        publishDir = [ enabled: false ]
    }

    withName: CLAIR3_POSTPROCESSING {
        publishDir = [
            path: { "${wfOutdir()}/Variant_calling/clair3/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                if (fn.endsWith('.variants.filtered.vcf') || fn.endsWith('.variants.unfiltered.vcf') || fn.endsWith('.variants.html')
                    ) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: CONSENSUS_BCFTOOLS {
        publishDir = [
            path: { "${wfOutdir()}/Consensus/bcftools/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                if (fn.endsWith('.consensus.fasta')) {
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }

    withName: ReadCount {
        publishDir = [
            path: { "${wfOutdir()}/Summary/readcount" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                def fn = filename.toString()
                if (fn.endsWith('read_counts.csv') || fn.endsWith('read_distribution.pdf')
                    || fn.endsWith('read_distribution.html')) {
                    // Strip task-relative prefix (e.g. read_count/) so files land flat in Summary/readcount/
                    return fn.tokenize('/').last()
                }
                return null
            }
        ]
    }
}
